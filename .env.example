# ============================================================
# AI-Powered Last Mile Delivery Automation — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# In production (ENV=production), set these as real env vars
# (e.g., via AWS Secrets Manager → ECS task definition).
# ============================================================

# ── Runtime mode ────────────────────────────────────────────
# "local"  → loads .env via python-dotenv
# "production" → expects real environment variables only
ENV=local

# ── OpenAI / LLM Gateway ───────────────────────────────────
OPENAI_API_KEY=
OPENAI_API_BASE=https://aibe.mygreatlearning.com/openai/v1

# ── LangChain / LangSmith Tracing ──────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=Last-Mile Logistics
LANGCHAIN_TRACING_V2=true

# ── ChromaDB (Cloud) ───────────────────────────────────────
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=Exception_Resolution_Playbook

# ── Optional overrides ─────────────────────────────────────
# CONFIG_PATH=           # Absolute path to config.yaml (auto-resolved if unset)
# PROJECT_ROOT=          # Absolute path to project root (auto-resolved if unset; set in Docker)
# GEN_LLM=gen_llm       # Config key for generation LLM
# EVAL_LLM=eval_llm     # Config key for evaluation LLM
# LOG_FORMAT=json        # "json" for structured logging, unset for plain text
